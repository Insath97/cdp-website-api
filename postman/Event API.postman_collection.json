{
  "info": {
    "name": "CDP Events API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for creating and managing Event resources"
  },
  "item": [
    {
      "name": "Create Event (JSON)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Test Event\",\n  \"created_date\": \"2026-05-14\",\n  \"description\": \"Short description here\",\n  \"status\": \"pending\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/events",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "events"
          ]
        }
      }
    },
    {
      "name": "Create Event (multipart/form-data)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "title",
              "value": "Test Event (multipart)",
              "type": "text"
            },
            {
              "key": "created_date",
              "value": "2026-05-14",
              "type": "text"
            },
            {
              "key": "description",
              "value": "Multipart upload description",
              "type": "text"
            },
            {
              "key": "status",
              "value": "pending",
              "type": "text"
            },
            {
              "key": "is_active",
              "value": "1",
              "type": "text"
            },
            {
              "key": "thumbnail_image",
              "type": "file",
              "src": "/path/to/thumbnail.jpg"
            },
            {
              "key": "galleries[]",
              "type": "file",
              "src": "/path/to/gallery1.jpg"
            },
            {
              "key": "galleries[]",
              "type": "file",
              "src": "/path/to/gallery2.jpg"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/events",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "events"
          ]
        }
      }
    },
    {
      "name": "Get Event by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/events/{{event_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "events",
            "{{event_id}}"
          ]
        }
      }
    },
    {
      "name": "Get Event by Slug",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/events/{{event_slug}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "events",
            "{{event_slug}}"
          ]
        }
      }
    },
    {
      "name": "Destroy (DELETE) - uses resource destroy",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/events/{{event_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "events",
            "{{event_id}}"
          ]
        }
      }
    },
    {
      "name": "Soft Delete (explicit)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/events/{{event_id}}/soft-delete",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "events",
            "{{event_id}}",
            "soft-delete"
          ]
        }
      }
    },
    {
      "name": "Restore Event",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/events/{{event_id}}/restore",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "events",
            "{{event_id}}",
            "restore"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "event_id",
      "value": ""
    },
    {
      "key": "event_slug",
      "value": ""
    }
  ]
}
